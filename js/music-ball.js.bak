(function(){

if(window.musicBallV22)
return;

window.musicBallV22=true;


let timer=null;

let isLong=false;

let isMove=false;


let startX,startY;

let startLeft,startTop;



const ball=document.querySelector("#music-ball");


if(!ball)
return;



ball.onpointerdown=function(e){


isLong=false;

isMove=false;


startX=e.clientX;

startY=e.clientY;


let rect=ball.getBoundingClientRect();


startLeft=rect.left;

startTop=rect.top;



timer=setTimeout(()=>{


isLong=true;


let audio=document.querySelector("#music-audio");


if(audio){

if(audio.paused)
audio.play();
else
audio.pause();

}


},600);



ball.setPointerCapture(
e.pointerId
);


};





ball.onpointermove=function(e){


let dx=e.clientX-startX;

let dy=e.clientY-startY;



if(
Math.abs(dx)>5 ||
Math.abs(dy)>5
){

isMove=true;

clearTimeout(timer);



let x=startLeft+dx;

let y=startTop+dy;



x=Math.max(
0,
Math.min(
window.innerWidth-60,
x
)
);


y=Math.max(
0,
Math.min(
window.innerHeight-60,
y
)
);



ball.style.left=x+"px";

ball.style.top=y+"px";


ball.style.right="auto";

ball.style.bottom="auto";


}



};





ball.onpointerup=function(){


clearTimeout(timer);



if(isMove){


let rect=
ball.getBoundingClientRect();


let x=rect.left;


if(
x <
window.innerWidth/2
){

ball.style.left="10px";


}else{


ball.style.left=
window.innerWidth-70+"px";


}



return;


}



if(isLong){

return;

}



//短按

let panel=
document.querySelector("#music-panel");


if(panel){

panel.classList.toggle("show");

}



};




})();