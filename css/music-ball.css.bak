#music-ball {
    position: fixed;
    right: 25px;
    bottom: 100px;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    z-index: 9999;

    background:
    linear-gradient(135deg,
    rgba(255,255,255,.9),
    rgba(240,240,240,.6));

    box-shadow:
    0 5px 20px rgba(0,0,0,.25);

    display:flex;
    align-items:center;
    justify-content:center;

    font-size:26px;

    user-select:none;
    touch-action:none;

    backdrop-filter:blur(10px);

    transition:.3s;
}


#music-ball.playing{
    animation:
    rotate 3s linear infinite;
}


@keyframes rotate {

from{
transform:rotate(0deg);
}

to{
transform:rotate(360deg);
}

}



#music-panel{

position:fixed;

right:20px;
bottom:170px;

width:260px;

max-height:350px;

background:
rgba(255,255,255,.9);

border-radius:20px;

padding:15px;

z-index:9998;

box-shadow:
0 10px 30px rgba(0,0,0,.2);

display:none;

overflow:auto;

}



#music-panel.show{

display:block;

}



.music-item{

padding:12px;

border-radius:10px;

cursor:pointer;

}



.music-item:hover{

background:#eee;

}



#music-title{

font-weight:bold;

margin-bottom:10px;

}



#music-lyric{

margin-top:15px;

font-size:14px;

color:#666;

text-align:center;

}
#music-panel{

position:fixed;

right:20px;

bottom:170px;

width:250px;

max-height:350px;

overflow:auto;

background:white;

border-radius:18px;

padding:15px;

box-shadow:
0 8px 30px rgba(0,0,0,.2);

